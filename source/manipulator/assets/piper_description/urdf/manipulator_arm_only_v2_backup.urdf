<?xml version="1.0" ?>
<!-- =================================================================================== -->
<!-- |    Arm-only variant of the Piper manipulator URDF.                              | -->
<!-- |    Rover platform (dummy_link, rover_platform) removed.                         | -->
<!-- |    arm_base is now the root link, fixed directly to the world.                  | -->
<!-- |    Original file: manipulator.urdf (kept for reference / sim2sim with rover)    | -->
<!-- =================================================================================== -->
<robot name="piper_arm">

  <!-- ══════════ Root: arm_base (fixed to world via fix_base=True) ══════════ -->
  <link name="arm_base">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.00473641164191482 2.56829134630247E-05 0.041451518036016"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/base_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.04"/>
      <geometry>
        <cylinder length="0.08" radius="0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- ══════════ Link 1 (base rotation) ══════════ -->
  <link name="link1">
    <inertial>
      <origin rpy="0 0 0" xyz="0.000121504734057468 0.000104632162460536 -0.00438597309559853"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/link1.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.04"/>
      <geometry>
        <cylinder length="0.02" radius="0.035"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint1" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.123"/>
    <parent link="arm_base"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-2.618" upper="2.168" velocity="5"/>
  </joint>

  <!-- ══════════ Link 2 (shoulder) ══════════ -->
  <link name="link2">
    <inertial>
      <origin rpy="0 0 0" xyz="0.198666145229743 -0.010926924140076 0.00142121714502687"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/link2.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.065" radius="0.03"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="0.12 0 0"/>
      <geometry>
        <box size="0.28 0.04 0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint2" type="revolute">
    <origin rpy="1.5708 -0.1359 -3.1416" xyz="0 0 0"/>
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="0" upper="3.14" velocity="5"/>
  </joint>

  <!-- ══════════ Link 3 (elbow) ══════════ -->
  <link name="link3">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0202737662122021 -0.133914995944595 -0.000458682652737356"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/link3.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.065" radius="0.03"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="-0.02 -0.12 0"/>
      <geometry>
        <box size="0.03 0.25 0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint3" type="revolute">
    <origin rpy="0 0 -1.7939" xyz="0.28503 0 0"/>
    <parent link="link2"/>
    <child link="link3"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-2.967" upper="0" velocity="5"/>
  </joint>

  <!-- ══════════ Link 4 (wrist 1) ══════════ -->
  <link name="link4">
    <inertial>
      <origin rpy="0 0 0" xyz="-9.66635791618542E-05 0.000876064475651083 -0.00496880904640868"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/link4.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.04"/>
      <geometry>
        <cylinder length="0.065" radius="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint4" type="revolute">
    <origin rpy="1.5708 0 0" xyz="-0.021984 -0.25075 0"/>
    <parent link="link3"/>
    <child link="link4"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-1.745" upper="1.745" velocity="5"/>
  </joint>

  <!-- ══════════ Link 5 (wrist 2) ══════════ -->
  <link name="link5">
    <inertial>
      <origin rpy="0 0 0" xyz="-4.10554118924211E-05 -0.0566486692356075 -0.0037205791677906"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/link5.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.03"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint5" type="revolute">
    <origin rpy="-1.5708 0 0" xyz="0 0 0"/>
    <parent link="link4"/>
    <child link="link5"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-1.22" upper="1.22" velocity="5"/>
  </joint>

  <!-- ══════════ Link 6 (wrist 3) ══════════ -->
  <link name="link6">
    <inertial>
      <origin rpy="0 0 0" xyz="-8.82590762930069E-05 9.0598378529832E-06 -0.002"/>
      <mass value="0.007"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/link6.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.03"/>
      <geometry>
        <cylinder length="0.06" radius="0.025"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint6" type="revolute">
    <origin rpy="1.5708 0 0" xyz="8.8259E-05 -0.091 0"/>
    <parent link="link5"/>
    <child link="link6"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-2.0944" upper="2.0944" velocity="3"/>
  </joint>

  <!-- ══════════ Gripper base (fixed to link6) ══════════ -->
  <link name="gripper_base">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.000183807162235591 8.05033155577911E-05 0.0321436689908876"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/gripper_base.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.03"/>
      <geometry>
        <cylinder length="0.06" radius="0.025"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint6_to_gripper_base" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="link6"/>
    <child link="gripper_base"/>
  </joint>

  <!-- ══════════ End effector (fixed to gripper_base) ══════════ -->
  <link name="link_end_effector"/>
  <joint name="joint_end_effector" type="fixed">
    <parent link="gripper_base"/>
    <child link="link_end_effector"/>
    <origin rpy="0 -1.57 0" xyz="0 0 0.1"/>
  </joint>

  <!-- ══════════ Gripper finger L (prismatic) ══════════ -->
  <link name="link7">
    <inertial>
      <origin rpy="0 0 0" xyz="0.00065123185041968 -0.0491929869131989 0.00972258769184025"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/link7.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="-0.149066 0 0" xyz="0 -0.04 0.01"/>
      <geometry>
        <box size="0.04 0.08 0.01"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint7" type="prismatic">
    <origin rpy="1.5708 0 0" xyz="0 0 0.1358"/>
    <parent link="gripper_base"/>
    <child link="link7"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" lower="0" upper="0.045" velocity="1"/>
  </joint>

  <!-- ══════════ Gripper finger R (prismatic) ══════════ -->
  <link name="link8">
    <inertial>
      <origin rpy="0 0 0" xyz="0.000651231850419722 -0.0491929869131991 0.00972258769184024"/>
      <mass value="0.01"/>
      <inertia ixx="0.02" ixy="0.00" ixz="0.00" iyy="0.02" iyz="0.00" izz="0.02"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/link8.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin rpy="-0.149066 0 0" xyz="0 -0.04 0.01"/>
      <geometry>
        <box size="0.04 0.08 0.01"/>
      </geometry>
    </collision>
  </link>
  <joint name="joint8" type="prismatic">
    <origin rpy="1.5708 0 -3.1416" xyz="0 0 0.1358"/>
    <parent link="gripper_base"/>
    <child link="link8"/>
    <axis xyz="0 0 -1"/>
    <limit effort="10" lower="-0.045" upper="0" velocity="1"/>
  </joint>

  <!-- ══════════ Camera on gripper (kept for reference) ══════════ -->
  <joint name="camera_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="camera_link_gripper"/>
    <origin rpy="0 -1.57 0" xyz="-0.055 0 0.07"/>
  </joint>
  <link name="camera_link_gripper">
    <visual>
      <origin rpy="0 1.57 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://piper_description/meshes/d405.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="carbon_fiber">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.01 0 0"/>
      <geometry>
        <box size="0.02 0.04 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1e-5"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0" iyy="1e-3" iyz="0.0" izz="1e-3"/>
    </inertial>
  </link>
  <joint name="camera_optical_joint_gripper" type="fixed">
    <origin rpy="-1.57 0 -1.57" xyz="0 0 0"/>
    <parent link="camera_link_gripper"/>
    <child link="camera_optical_gripper"/>
  </joint>
  <link name="camera_optical_gripper">
    <inertial>
      <mass value="1e-5"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0" iyy="1e-3" iyz="0.0" izz="1e-3"/>
    </inertial>
  </link>

</robot>
